# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Application ID (Client ID) from the Discord developer portal
CLIENT_ID=your-client-id-here

# Run Playwright in headless mode (default: true)
HEADLESS=true

# Default polling interval in minutes (default: 10)
DEFAULT_POLL_INTERVAL_MINUTES=10

# How many days out to track events (default: 30)
EVENT_HORIZON_DAYS=30
